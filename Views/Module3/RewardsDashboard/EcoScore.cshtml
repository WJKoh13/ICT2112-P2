@* Views/Module3/RewardsDashboard/EcoScore.cshtml *@
@{
    ViewData["Title"] = "Eco Score";
    int    score   = ViewBag.EcoScore;
    int    orderId = ViewBag.OrderId;
    string badge   = score >= 80 ? "success" : score >= 50 ? "warning" : "danger";
    string label   = score >= 80 ? "Excellent 🌿" : score >= 50 ? "Good 🌱" : "Needs Improvement ♻️";
}

<div class="container mt-4" style="max-width:480px">
    <h4>Eco Score — Order #@orderId</h4>

    <div class="card text-center mt-3">
        <div class="card-body">
            <h1 class="display-3 fw-bold text-@badge">@score</h1>
            <p class="fs-5">@label</p>
            <div class="progress mt-2" style="height:20px">
                <div class="progress-bar bg-@badge"
                     role="progressbar"
                     style="width:@score%"
                     aria-valuenow="@score"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
            </div>
            <p class="text-muted mt-2 small">Score is based on total carbon footprint (lower carbon = higher score).</p>
        </div>
    </div>

    <a asp-action="DisplayRewards" asp-controller="RewardsDashboard"
       class="btn btn-outline-secondary mt-3">
        ← Back to Dashboard
    </a>
</div>
