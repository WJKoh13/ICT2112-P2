@model IReadOnlyList<ProRental.Models.Module3.P2_1.ShippingOptionSummary>
@* Feature 1 landing page: shows the generated FAST/CHEAP/GREEN options and lets the
   customer continue into the compare flow or confirm a single choice. *@
@* by: ernest *@
@{
    ViewData["Title"] = "Shipping Options";
    var orderId = Model.FirstOrDefault()?.OrderId ?? 0;
}

<section class="py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-3 mb-4">
        <div>
            <p class="text-uppercase text-muted small mb-1">Checkout</p>
            <h1 class="h3 mb-1">Choose a shipping option</h1>
            <p class="text-muted mb-0">Fastest, cheapest, and greenest options are shown below.</p>
        </div>
        @if (orderId != 0)
        {
            <a asp-action="CompareOptions" asp-route-orderId="@orderId" class="btn btn-outline-primary">Compare options</a>
        }
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No shipping options are available for this order yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var option in Model)
            {
                <div class="col-12 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h2 class="h5 mb-1">@option.DisplayName</h2>
                                    <span class="badge text-bg-light">@option.PreferenceType</span>
                                </div>
                                <span class="fs-4 fw-semibold">@option.Cost.ToString("C")</span>
                            </div>

                            <dl class="row small mb-4">
                                <dt class="col-6 text-muted">Delivery</dt>
                                <dd class="col-6 text-end mb-2">@option.DeliveryDays day(s)</dd>
                                <dt class="col-6 text-muted">Carbon</dt>
                                <dd class="col-6 text-end mb-2">@option.CarbonFootprintKg.ToString("0.##") kg CO2</dd>
                                <dt class="col-6 text-muted">Transport</dt>
                                <dd class="col-6 text-end mb-0">@option.TransportModeLabel</dd>
                            </dl>

                            <form asp-action="SelectShippingOption" method="post" class="mt-auto">
                                <input type="hidden" name="orderId" value="@option.OrderId" />
                                <input type="hidden" name="optionId" value="@option.OptionId" />
                                <button type="submit" class="btn btn-primary w-100">Select option</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
